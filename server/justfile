set dotenv-load
set export

# list available recipes
default:
  just --list

# lint project files
lint:
  golangci-lint run -c .golangci.yaml

# build fleet project
build:
    go build -v ./...

# install fleet
install:
    go install -v ./cmd/fleetd

# run local server in docker compose with watch enabled
dev: _build-plugins-docker start
  docker compose up --watch fleet-api --remove-orphans --no-deps

# run fleet with alerts stack turned on
dev-alerts: _build-plugins-docker
  docker compose -f docker-compose.yaml -f docker-compose.alerts.yaml up --wait
  docker compose -f docker-compose.yaml -f docker-compose.alerts.yaml up --watch fleet-api --remove-orphans --no-deps

# run fleet with the alerts stack plus host system monitoring (CPU/RAM/disk alerts, slow-query dashboard)
dev-system-monitoring: _build-plugins-docker
  docker compose -f docker-compose.yaml -f docker-compose.alerts.yaml -f docker-compose.system-monitoring.yaml up --wait
  docker compose -f docker-compose.yaml -f docker-compose.alerts.yaml -f docker-compose.system-monitoring.yaml up --watch fleet-api --remove-orphans --no-deps

# start services in docker compose
start:
  docker compose up --wait

# stop services in docker
stop:
  docker compose down

# run all tests (DB_PASSWORD defaults to 'fleet' for local/CI testing)
test:
    DB_PASSWORD="${DB_PASSWORD:-fleet}" go test ./... -skip ./generated/...

# run e2e plugin integration test
test-plugin-integration:
    go test -v -tags=e2e ./e2e -run TestPluginIntegration

# format project files
format:
  goimports -w .

# run linting and tests together (non-mutating)
check: lint test

# run all code gen tasks
gen: gen-db-queries gen-sdk-protos gen-go

# generate query via sqlc
gen-db-queries:
  sqlc generate
  go run ./tools/generate-sqlc-retrier -querier generated/sqlc/querier.go -out generated/sqlc/retrying_querier.gen.go
  goimports -w generated/sqlc

# generate SDK protobuf code
gen-sdk-protos:
  buf generate
  goimports -w sdk/v1/pb/generated

# go generate, this will run all go:generate directives in the project
gen-go:
  go generate ./...

# start db (PostgreSQL via TimescaleDB)
db-up:
  docker compose up --wait timescaledb

# run a db migration
db-migrate:
  migrate -database "postgres://fleet:fleet@localhost:5432/fleet?sslmode=disable" -path migrations up

# stop the db
db-down:
  docker compose down timescaledb

# tear down the db by running down migrations
db-reset:
  migrate -database "postgres://fleet:fleet@localhost:5432/fleet?sslmode=disable" -path migrations down

# launch psql shell for interacting with the db started via db-up
db-shell:
  psql -h 127.0.0.1 -U fleet -d fleet

# create a new migration
db-migration-new name:
  migrate create -ext sql -dir migrations -seq {{name}}

# run the local server (requires env: use --dotenv-filename .env.local, create .env file, or set vars manually)
_run: db-up install
     ../.hermit/go/bin/fleetd

# seed telemetry data for dashboard testing (always clears old synthetic rows first)
# examples:
#   just seed-telemetry --days 10 --devices 3
#   just seed-telemetry --clean-up
#   just seed-telemetry --days 30 --outliers
seed-telemetry *args:
    go run ./devtools/seedtelemetry {{args}}

# start MQTT simulator brokers and browser control UI
mqtt-sim-up:
  #!/usr/bin/env bash
  set -euo pipefail
  docker compose -f docker-compose.yaml -f docker-compose.mqtt-sim.yaml up -d --build mqtt-sim-primary mqtt-sim-secondary mqtt-sim-ui
  for port in 1883 1884 4183; do
    ready=false
    for _ in $(seq 1 60); do
      if (echo >"/dev/tcp/127.0.0.1/${port}") >/dev/null 2>&1; then
        ready=true
        break
      fi
      sleep 0.25
    done
    if [ "${ready}" != true ]; then
      echo "MQTT simulator did not become ready on 127.0.0.1:${port}" >&2
      docker compose -f docker-compose.yaml -f docker-compose.mqtt-sim.yaml logs --tail=120 mqtt-sim-primary mqtt-sim-secondary mqtt-sim-ui >&2 || true
      exit 1
    fi
  done
  echo "MQTT simulator UI: http://localhost:4183"
  echo "Proto Fleet Docker source config: primary=192.168.2.240 secondary=192.168.2.241 port=1883 topic=maestro/target"

# rebuild and restart MQTT simulator services
mqtt-sim-rebuild:
  docker compose -f docker-compose.yaml -f docker-compose.mqtt-sim.yaml up -d --build --force-recreate mqtt-sim-primary mqtt-sim-secondary mqtt-sim-ui

# stop MQTT simulator services
mqtt-sim-down:
  docker compose -f docker-compose.yaml -f docker-compose.mqtt-sim.yaml stop mqtt-sim-primary mqtt-sim-secondary mqtt-sim-ui
  docker compose -f docker-compose.yaml -f docker-compose.mqtt-sim.yaml rm -f mqtt-sim-primary mqtt-sim-secondary mqtt-sim-ui

# follow MQTT simulator logs
mqtt-sim-logs:
  docker compose -f docker-compose.yaml -f docker-compose.mqtt-sim.yaml logs -f mqtt-sim-primary mqtt-sim-secondary mqtt-sim-ui

# start the Modbus TCP simulator and recreate fleet-api with its dev allowlist
modbus-sim-up:
  docker compose -f docker-compose.yaml -f docker-compose.modbus-sim.yaml up -d --build modbus-sim fleet-api
  just _modbus-sim-ready

# rebuild and restart the Modbus TCP simulator and allowlisted fleet-api
modbus-sim-rebuild:
  docker compose -f docker-compose.yaml -f docker-compose.modbus-sim.yaml up -d --build --force-recreate modbus-sim fleet-api
  just _modbus-sim-ready

# stop the Modbus TCP simulator and remove its dev allowlist from fleet-api
modbus-sim-down:
  docker compose -f docker-compose.yaml -f docker-compose.modbus-sim.yaml stop modbus-sim
  docker compose -f docker-compose.yaml -f docker-compose.modbus-sim.yaml rm -f modbus-sim
  docker compose -f docker-compose.yaml up -d --build --no-deps --force-recreate fleet-api

# follow Modbus TCP simulator logs
modbus-sim-logs:
  docker compose -f docker-compose.yaml -f docker-compose.modbus-sim.yaml logs -f modbus-sim

_modbus-sim-ready:
  #!/usr/bin/env bash
  set -euo pipefail
  simulator_ready=false
  for _ in $(seq 1 60); do
    if (echo >"/dev/tcp/127.0.0.1/5502") >/dev/null 2>&1; then
      simulator_ready=true
      break
    fi
    sleep 0.25
  done
  fleet_api_ready=false
  for _ in $(seq 1 120); do
    if curl --fail --silent --show-error "http://127.0.0.1:4000/health/ready" >/dev/null 2>&1; then
      fleet_api_ready=true
      break
    fi
    sleep 0.5
  done
  if [ "${simulator_ready}" != true ] || [ "${fleet_api_ready}" != true ]; then
    if [ "${simulator_ready}" != true ]; then
      echo "Modbus simulator did not become ready on 127.0.0.1:5502" >&2
    fi
    if [ "${fleet_api_ready}" != true ]; then
      echo "fleet-api did not become ready on 127.0.0.1:4000" >&2
    fi
    docker compose -f docker-compose.yaml -f docker-compose.modbus-sim.yaml logs --tail=120 modbus-sim fleet-api >&2 || true
    exit 1
  fi
  echo "Modbus simulator host endpoint: 127.0.0.1:5502"
  echo 'Proto Fleet Docker driver_config: {"endpoint":"192.168.2.242","port":5502,"unit_id":1,"register_address":1,"write_mode":"coil"}'
  echo "Commission the site control allowlist with: 192.168.2.242/32"

# wipe and rebuild all docker compose services from scratch (includes plugin rebuild)
rebuild-all: _build-plugins-docker rebuild-services

# wipe and rebuild docker compose services, reusing existing plugin binaries
rebuild-services:
    # `--rmi local` keeps pulled images (jaeger, otel-collector) to avoid re-pulling.
    docker compose down --rmi local --volumes && docker compose up --build -d

_build-plugins-docker:
  #!/usr/bin/env bash
  set -euo pipefail
  cd .. && just build-plugins-docker

# restart and rebuild fleet-api only
rebuild-fleet-api:
  docker compose up fleet-api -d --build --force-recreate
